#!/usr/bin/env python3

import difflib
import hashlib
import shlex
import subprocess
import sys
from pathlib import Path

COMPILER = "./recaf"
TMP = Path("/tmp/recaf-test")
VALUE_ARGS = {"-l", "--library", "-t", "--target"}
GREEN = "\033[32m"
RED = "\033[31m"
BOLD = "\033[1m"
DIM = "\033[2m"
CYAN = "\033[36m"
RESET = "\033[0m"


def color(text, ansi):
    return f"{ansi}{text}{RESET}"


def die(message, code=2):
    print(message, file=sys.stderr)
    sys.exit(code)


def usage():
    print("Usage: ./test [recaf args] <file|dir>...")
    print("Directories are searched recursively for .pas files.")
    sys.exit(0)


def split_args(argv):
    compiler_args, roots = [], []
    i = 0
    while i < len(argv):
        arg = argv[i]
        path = Path(arg)
        if arg in {"-h", "--help"}:
            usage()
        if arg in {"-o", "--output"}:
            die("./test controls -o/--output so executables stay in /tmp/recaf-test")
        if path.exists():
            roots.append(path)
        else:
            compiler_args.append(arg)
            if arg in VALUE_ARGS:
                i += 1
                if i >= len(argv):
                    die(f"missing value after {arg}")
                compiler_args.append(argv[i])
        i += 1
    return compiler_args, roots


def sources(roots):
    found = []
    for path in roots:
        if path.is_dir():
            found += sorted(path.rglob("*.pas"))
        elif path.is_file():
            found.append(path)
    return found


def exe_for(src):
    digest = hashlib.sha1(str(src.resolve()).encode()).hexdigest()[:8]
    name = "".join(c if c.isalnum() or c in "-_" else "_" for c in src.stem)
    return TMP / f"recaf-{name}-{digest}"


def run(cmd, stdin=None):
    try:
        return subprocess.run(cmd, stdin=stdin, capture_output=True, text=True)
    except FileNotFoundError:
        die(color(f"could not run {cmd[0]}", RED))


def compile_all(srcs, exes, args):
    TMP.mkdir(parents=True, exist_ok=True)
    cmd = [COMPILER]
    for i, src in enumerate(srcs):
        if i:
            cmd.append("--and")
        cmd += [str(src), "-o", str(exes[src]), *args]

    print(color(shlex.join(cmd), DIM), flush=True)
    proc = run(cmd)
    if proc.returncode:
        print(color("FAIL", RED) + ": compilation failed")
        print(proc.stdout, end="")
        print(proc.stderr, end="", file=sys.stderr)
        return False
    return True


def print_diff(src, expected, actual):
    diff = difflib.unified_diff(
        expected.splitlines(),
        actual.splitlines(),
        fromfile=str(src.with_suffix(".out")),
        tofile="actual",
        lineterm="",
    )
    for line in diff:
        if line.startswith(("+", "-")) and not line.startswith(("+++", "---")):
            print(color(line, GREEN if line.startswith("+") else RED))
        elif line.startswith("@@"):
            print(color(line, CYAN))
        else:
            print(line)


def test(src, exe):
    expected = src.with_suffix(".out")
    if not expected.exists():
        print(f"{color('FAIL', RED)} {src}: missing {expected}")
        return False

    input_file = src.with_suffix(".in")
    with (input_file.open() if input_file.exists() else open("/dev/null")) as stdin:
        proc = run([str(exe)], stdin=stdin)

    if proc.returncode:
        print(f"{color('FAIL', RED)} {src}: exited {proc.returncode}")
        print(proc.stderr, end="", file=sys.stderr)
        return False

    expected_text = expected.read_text()
    if proc.stdout.rstrip() != expected_text.rstrip():
        print(f"{color('FAIL', RED)} {src}: output differs")
        print_diff(src, expected_text.rstrip(), proc.stdout.rstrip())
        return False

    print(f"{color('PASS', GREEN)} {src}")
    return True


def main():
    compiler_args, roots = split_args(sys.argv[1:])
    if not roots:
        die("no input files or directories")

    srcs = sources(roots)
    if not srcs:
        die("no source files found", 0)

    exes = {src: exe_for(src) for src in srcs}
    if not compile_all(srcs, exes, compiler_args):
        sys.exit(1)

    passed = 0
    for src in srcs:
        if test(src, exes[src]):
            passed += 1

    total = len(srcs)
    summary = f"{passed}/{total} passed"
    print(color(summary, GREEN if passed == total else RED + BOLD))
    sys.exit(0 if passed == total else 1)


if __name__ == "__main__":
    main()
