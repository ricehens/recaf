PROGRAM FANCY_ARITHMETIC;

FUNCTION GET(X: INT64): INT64;
BEGIN
    GET := X
END;

VAR
    X, Y, Z, A: INT64;
BEGIN
    X := GET(27);
    Y := GET(31);
    Z := GET(50);
    A := GET(1000000000000000);

    WRITELN(X MOD 4);
    WRITELN(Y DIV 8);
    WRITELN((Z MOD 38) DIV 5);
    WRITELN(A DIV 3000000000000);
    WRITELN(500000000 + A);
    WRITELN(2 * A);
END.
