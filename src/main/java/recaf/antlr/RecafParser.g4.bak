parser grammar RecafParser;
options { tokenVocab = RecafLexer; }

program: module_decl? (import_decl | use_decl)* (const_decl | type_decl | var_decl | method_decl)* EOF;

module_decl: MODULE path SEMICOLON;
use_decl: USE ID SEMICOLON;
import_decl: IMPORT path SEMICOLON;
path: ID (DOT ID)*;

const_decl: CONST ID (COLON type)? EQUALS literal SEMICOLON;
constant: ID | INT_LITERAL;

type_decl: TYPE ID LPAREN constant RPAREN LBRACE field_decl* RBRACE;
field_decl: ID (COMMA ID)* COLON recaf_type_or_array SEMICOLON;

var_decl: VAR field_decl;
var_decl_init: var_decl_init_sub SEMICOLON;
var_decl_init_sub: VAR ID (COLON recaf_type)? EQUALS expr;
recaf_type_or_array: recaf_type (LBRACK constant RBRACK)*;
recaf_type: type | ID;
type: INT | LONG | BOOL;

method_decl: FUNC ID LPAREN params RPAREN COLON (recaf_type | VOID) block;
params: (param (COMMA param)*)?;
param: ID COLON recaf_type; // cannot infer parameter type

block: LBRACE (statement)* RBRACE;
statement: var_decl
         | var_decl_init
         | assign_statement
         | method_call_statement
         | if_else
         | for_loop
         | while_loop
         | return_statement
         | break_statement
         | continue_statement;

assign_statement: assign_sub SEMICOLON;
assign_sub: postfix
          | prefix
          | location assign_op expr;
assign_op: EQUALS | PLUS_EQUALS | MINUS_EQUALS | TIMES_EQUALS | DIVIDES_EQUALS | MOD_EQUALS;
postfix: location increment;
prefix: increment location;
increment: PLUS_PLUS | MINUS_MINUS;

method_call_statement: method_call SEMICOLON;
method_call: ID LPAREN args RPAREN;
args: (arg (COMMA arg)*)?;
arg: expr | STRING_LITERAL;

location: link | base DOT link (DOT link)*;
base: link | method_call | LPAREN expr RPAREN;
link: ID (LBRACK expr RBRACK)*;

expr: location
    | method_call
    | literal
    | MINUS expr
    | NOT expr
    | LPAREN INT RPAREN expr // type casts
    | LPAREN LONG RPAREN expr
    | expr mul_op expr // */
    | expr add_op expr // +-
    | expr rel_op expr // relational
    | expr eq_op expr // equality
    | expr AND expr // logical and
    | expr OR expr // logical or
    | <assoc=right> expr QUESTION expr COLON expr // ternary
    | LPAREN expr RPAREN
    | NEW ID
    | assign_sub;

mul_op: TIMES | DIVIDES | MOD;
add_op: PLUS | MINUS;
rel_op: LT | GT | LEQ | GEQ;
eq_op: EQUALS_EQUALS | NEQ;

literal: INT_LITERAL | LONG_LITERAL | CHAR_LITERAL | BOOL_LITERAL;

if_else: IF LPAREN expr RPAREN clause (ELSE clause)?;
for_loop: FOR LPAREN for_init? SEMICOLON expr? SEMICOLON assign_sub? RPAREN clause;
for_init: assign_sub | var_decl_init_sub;
while_loop: WHILE LPAREN expr RPAREN clause;
clause: block | statement;

return_statement: RETURN (expr)? SEMICOLON;

break_statement: BREAK SEMICOLON;
continue_statement: CONTINUE SEMICOLON;
