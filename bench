#!/usr/bin/env python3

import hashlib
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path

GREEN = "\033[32m"
RED = "\033[31m"
BOLD = "\033[1m"
DIM = "\033[2m"
CYAN = "\033[36m"
YELLOW = "\033[33m"
RESET = "\033[0m"

SOURCE_EXTENSIONS = {
    "recaf": ".pas",
    "fpc": ".pp",
    "gcc": ".c",
    "clang": ".c",
}
COMPILERS = tuple(SOURCE_EXTENSIONS)
OPT_LEVELS = {
    "recaf": [(f"-O{level}", [f"-O{level}"]) for level in range(4)],
    "fpc": [("-O0", ["-O-"]), *[(f"-O{level}", [f"-O{level}"]) for level in range(1, 5)]],
    "gcc": [(f"-O{level}", [f"-O{level}"]) for level in range(4)],
    "clang": [(f"-O{level}", [f"-O{level}"]) for level in range(4)],
}
BENCHMARK = Path("benchmark")
TMP = Path("/tmp")


def color(text, ansi):
    return f"{ansi}{text}{RESET}"


def die(message, code=2):
    print(message, file=sys.stderr)
    sys.exit(code)


def usage():
    print("""Usage:
  ./bench <recaf|fpc|gcc|clang> <benchmark> <opts...>
  ./bench all <benchmark>""")
    sys.exit(0)


def safe_name(name):
    return "".join(c if c.isalnum() or c in "-_" else "_" for c in name)


def exe_for(src, compiler, opts):
    key = "\0".join([str(src.resolve()), compiler, *opts])
    digest = hashlib.sha1(key.encode()).hexdigest()[:8]
    return TMP / f"bench-{safe_name(src.stem)}-{compiler}-{digest}"


def out_for(src, compiler, opts):
    return exe_for(src, compiler, opts).with_suffix(".out")


def compile_cmd(compiler, src, exe, opts):
    if compiler == "recaf":
        return ["./run.sh", str(src), "-o", str(exe), *opts]
    if compiler == "fpc":
        return ["fpc", str(src), f"-o{exe}", *opts]
    cmd = [compiler, str(src), "-o", str(exe), *opts]
    if "-lm" not in opts:
        cmd.append("-lm")
    return cmd


def run(cmd, **kwargs):
    try:
        return subprocess.run(cmd, **kwargs)
    except FileNotFoundError:
        die(color(f"could not run {cmd[0]}", RED))


def print_cmd(cmd, stdin=None, stdout=None):
    rendered = shlex.join([str(part) for part in cmd])
    if stdin is not None:
        rendered += f" < {shlex.quote(str(stdin))}"
    if stdout is not None:
        rendered += f" > {shlex.quote(str(stdout))}"
    print(color(rendered, DIM), flush=True)


def time_command():
    if Path("/usr/bin/time").exists():
        return ["/usr/bin/time", "-p"]
    return ["time", "-p"]


def print_time(stderr):
    times = {}
    other = []
    for line in stderr.splitlines():
        pieces = line.split()
        if len(pieces) == 2 and pieces[0] in {"real", "user", "sys"}:
            times[pieces[0]] = pieces[1]
        elif line:
            other.append(line)

    for line in other:
        print(line, file=sys.stderr)

    if times:
        summary = "  ".join(f"{name} {times[name]}s" for name in ("real", "user", "sys") if name in times)
        print(color("time: ", CYAN) + summary)
    else:
        print(color("time output was not recognized", YELLOW), file=sys.stderr)


def paths_for(compiler, benchmark):
    src = BENCHMARK / f"{benchmark}{SOURCE_EXTENSIONS[compiler]}"
    if not src.exists():
        die(f"missing input file: {src}")

    expected = BENCHMARK / f"{benchmark}.out"
    if not expected.exists():
        die(f"missing expected output: {expected}")

    infile = BENCHMARK / f"{benchmark}.in"
    stdin_path = infile if infile.exists() else Path(os.devnull)
    return src, stdin_path, expected


def compile_benchmark(compiler, src, opts):
    exe = exe_for(src, compiler, opts)
    compile = compile_cmd(compiler, src, exe, opts)

    print_cmd(compile)
    proc = run(compile, capture_output=True, text=True)
    if proc.returncode:
        if proc.stdout:
            print(proc.stdout, end="")
        if proc.stderr:
            print(proc.stderr, end="", file=sys.stderr)
        die(color("compile failed", RED), proc.returncode)

    return exe


def check_output(actual, expected):
    if actual.read_bytes().rstrip() != expected.read_bytes().rstrip():
        die(color(f"incorrect output: {actual} differs from {expected}", RED), 1)


def run_once(compiler, benchmark, opts):
    src, stdin_path, expected = paths_for(compiler, benchmark)
    exe = compile_benchmark(compiler, src, opts)
    actual = out_for(src, compiler, opts)
    timed = [*time_command(), str(exe)]
    print_cmd(timed, stdin=stdin_path, stdout=actual)

    with stdin_path.open("rb") as stdin, actual.open("wb") as stdout:
        proc = run(timed, stdin=stdin, stdout=stdout, stderr=subprocess.PIPE, text=True)

    print_time(proc.stderr)
    if proc.returncode:
        die(color(f"program exited with status {proc.returncode}", RED), proc.returncode)

    check_output(actual, expected)


def run_hyperfine(name, exe, stdin_path, actual):
    report = TMP / f"bench-{safe_name(name)}.json"
    cmd = [
        "hyperfine",
        "-w", "1",
        "-r", "5",
        "--input", str(stdin_path),
        "--output", str(actual),
        "--export-json", str(report),
        "--command-name", name,
        str(exe),
    ]
    print_cmd(cmd)
    proc = run(cmd)
    if proc.returncode:
        die(color(f"hyperfine failed for {name}", RED), proc.returncode)

    try:
        with report.open() as f:
            return json.load(f)["results"][0]["mean"]
    except (OSError, KeyError, IndexError, json.JSONDecodeError) as e:
        die(color(f"could not read hyperfine result for {name}: {e}", RED), 1)


def format_duration(seconds):
    if seconds < 0.001:
        return f"{seconds * 1_000_000:.2f} us"
    if seconds < 1:
        return f"{seconds * 1_000:.2f} ms"
    return f"{seconds:.3f} s"


def print_summary(results):
    compiler_width = max(len("Compiler"), *(len(row["compiler"]) for row in results))
    opt_width = max(len("Opt"), *(len(row["opt"]) for row in results))
    mean_width = max(len("Mean"), *(len(format_duration(row["mean"])) for row in results))

    print()
    print(color("hyperfine summary", BOLD))
    print(f"{'Compiler':<{compiler_width}}  {'Opt':<{opt_width}}  {'Mean':>{mean_width}}")
    print(f"{'-' * compiler_width}  {'-' * opt_width}  {'-' * mean_width}")
    for row in results:
        print(f"{row['compiler']:<{compiler_width}}  {row['opt']:<{opt_width}}  {format_duration(row['mean']):>{mean_width}}")


def run_all(benchmark):
    results = []
    actual = TMP / f"bench-{safe_name(benchmark)}-all.out"

    for compiler in COMPILERS:
        src, stdin_path, expected = paths_for(compiler, benchmark)
        for opt_name, opt_args in OPT_LEVELS[compiler]:
            name = f"{compiler} {opt_name}"
            print()
            print(color(name, BOLD))
            exe = compile_benchmark(compiler, src, opt_args)
            mean = run_hyperfine(name, exe, stdin_path, actual)
            check_output(actual, expected)
            results.append({"compiler": compiler, "opt": opt_name, "mean": mean})

    print_summary(results)


def main():
    if len(sys.argv) == 2 and sys.argv[1] in {"-h", "--help"}:
        usage()
    if len(sys.argv) < 3:
        usage()

    compiler = sys.argv[1]
    benchmark = sys.argv[2]
    opts = sys.argv[3:]

    if compiler == "all":
        if opts:
            die("all supplies the optimization options; do not pass extra compiler options")
        run_all(benchmark)
        return

    if compiler not in COMPILERS:
        die(f"unknown compiler: {compiler}")

    run_once(compiler, benchmark, opts)


if __name__ == "__main__":
    main()
